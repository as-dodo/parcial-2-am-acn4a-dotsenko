<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/txtDialogDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_new_racha_description"
        android:textColor="@color/gray_dark"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/inputRachaNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/dialog_new_racha_name_hint"
        android:inputType="textCapSentences"
        android:maxLines="1" />

    <EditText
        android:id="@+id/inputRachaIcono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/dialog_new_racha_icon_hint"
        android:inputType="text"
        android:maxLength="4"
        android:maxLines="1" />

    <EditText
        android:id="@+id/inputRachaDias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/dialog_new_racha_days_hint"
        android:inputType="number"
        android:maxLines="1" />

</LinearLayout>
